{
  "name": "json-hydrate",
  "displayName": "Json Hydrate",
  "description": "Visualize JSON files as interactive collapsible trees with UUID highlighting, datetime detection, and custom rules.",
  "version": "0.1.0",
  "publisher": "anirudh-kumar",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "json",
    "tree",
    "viewer",
    "visualizer",
    "uuid",
    "datetime",
    "hydrate"
  ],
  "icon": "assets/icon.png",
  "main": "./build/extension.js",
  "activationEvents": [
    "workspaceContains:**/*.json",
    "onLanguage:json",
    "onLanguage:jsonc"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jsonhydrate.open",
        "title": "Open Json Hydrate View",
        "category": "Json Hydrate",
        "icon": {
          "light": "./assets/icon-light.svg",
          "dark": "./assets/icon-dark.svg"
        }
      },
      {
        "command": "jsonhydrate.openSelected",
        "title": "Open Selection in Json Hydrate",
        "category": "Json Hydrate"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jsonhydrate.open",
          "when": "resourceExtname == .json || editorLangId == json || editorLangId == jsonc",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "jsonhydrate.openSelected",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Json Hydrate",
      "properties": {
        "jsonhydrate.uuid.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight UUID values with a distinct color."
        },
        "jsonhydrate.uuid.color": {
          "type": "string",
          "default": "#c792ea",
          "description": "Color for UUID values."
        },
        "jsonhydrate.uuid.additionalPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional regex patterns to detect as UUIDs (e.g. custom ID formats)."
        },
        "jsonhydrate.datetime.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Detect and enrich datetime values with hover tooltips."
        },
        "jsonhydrate.datetime.color": {
          "type": "string",
          "default": "#ffcb6b",
          "description": "Color for datetime values."
        },
        "jsonhydrate.datetime.keyHints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "time",
            "date",
            "created",
            "updated",
            "timestamp",
            "_at",
            "_on",
            "epoch",
            "expires",
            "modified"
          ],
          "description": "Key name substrings that hint a numeric value is a timestamp. Used for 10/13-digit numbers."
        },
        "jsonhydrate.datetime.unixRangeMin": {
          "type": "number",
          "default": 0,
          "description": "Minimum Unix timestamp (seconds) to consider valid (default: 1970-01-01)."
        },
        "jsonhydrate.datetime.unixRangeMax": {
          "type": "number",
          "default": 4102444800,
          "description": "Maximum Unix timestamp (seconds) to consider valid (default: 2100-01-01)."
        },
        "jsonhydrate.customRules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Rule name (shown in tooltips)."
              },
              "pattern": {
                "type": "string",
                "description": "Regex pattern to match values."
              },
              "color": {
                "type": "string",
                "description": "Highlight color (hex)."
              },
              "tooltip": {
                "type": "string",
                "description": "Tooltip text (use $0 for full match, $1-$9 for groups)."
              },
              "keyFilter": {
                "type": "string",
                "description": "Optional: only apply to values under keys matching this regex."
              }
            },
            "required": [
              "name",
              "pattern",
              "color"
            ]
          },
          "default": [],
          "markdownDescription": "Add custom value detection rules. Each rule is a regex that, when matched, highlights the value in the specified color.\n\nExample — detect AWS ARNs:\n```json\n{\n  \"name\": \"AWS ARN\",\n  \"pattern\": \"^arn:aws:[a-z0-9-]+:[a-z0-9-]*:[0-9]*:.+$\",\n  \"color\": \"#ff9e64\",\n  \"tooltip\": \"AWS Resource: $0\"\n}\n```"
        },
        "jsonhydrate.markdown.keyHints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "body",
            "markdown",
            "description",
            "notes",
            "summary",
            "comment",
            "readme",
            "md"
          ],
          "description": "Key name substrings that hint a value should be rendered as markdown."
        },
        "jsonhydrate.markdown.autoRender": {
          "type": "boolean",
          "default": false,
          "description": "Automatically render values detected as Markdown blocks without manual toggling."
        },
        "jsonhydrate.theme.dark.background": {
          "type": "string",
          "default": "#0a0a0c",
          "description": "Dark Theme: Background color (used in standalone mode)."
        },
        "jsonhydrate.theme.dark.keys": {
          "type": "string",
          "default": "#59b8ff",
          "description": "Dark Theme: Color for JSON keys."
        },
        "jsonhydrate.theme.dark.strings": {
          "type": "string",
          "default": "#98c379",
          "description": "Dark Theme: Color for string values."
        },
        "jsonhydrate.theme.dark.numbers": {
          "type": "string",
          "default": "#e8c479",
          "description": "Dark Theme: Color for numeric values."
        },
        "jsonhydrate.theme.dark.booleans": {
          "type": "string",
          "default": "#f85c50",
          "description": "Dark Theme: Color for boolean/null values."
        },
        "jsonhydrate.theme.dark.uuid": {
          "type": "string",
          "default": "#c792ea",
          "description": "Dark Theme: Color for UUID values."
        },
        "jsonhydrate.theme.dark.datetime": {
          "type": "string",
          "default": "#ffcb6b",
          "description": "Dark Theme: Color for datetime values."
        },
        "jsonhydrate.theme.light.background": {
          "type": "string",
          "default": "#ffffff",
          "description": "Light Theme: Background color (used in standalone mode)."
        },
        "jsonhydrate.theme.light.keys": {
          "type": "string",
          "default": "#005cc5",
          "description": "Light Theme: Color for JSON keys."
        },
        "jsonhydrate.theme.light.strings": {
          "type": "string",
          "default": "#22863a",
          "description": "Light Theme: Color for string values."
        },
        "jsonhydrate.theme.light.numbers": {
          "type": "string",
          "default": "#d73a49",
          "description": "Light Theme: Color for numeric values."
        },
        "jsonhydrate.theme.light.booleans": {
          "type": "string",
          "default": "#d73a49",
          "description": "Light Theme: Color for boolean/null values."
        },
        "jsonhydrate.theme.light.uuid": {
          "type": "string",
          "default": "#7b1fa2",
          "description": "Light Theme: Color for UUID values."
        },
        "jsonhydrate.theme.light.datetime": {
          "type": "string",
          "default": "#af8600",
          "description": "Light Theme: Color for datetime values."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "dev": "vite",
    "build": "vite build && node esbuild.config.mjs --production",
    "build:dev": "vite build && node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "watch:webview": "vite build --watch",
    "test": "vitest",
    "lint": "eslint src ext-src tests",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "launch": "npm run build:dev && code --extensionDevelopmentPath=$PWD $PWD/tests/fixtures $PWD/tests/fixtures/test-data.json"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-json-tree": "^0.20.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.86.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
